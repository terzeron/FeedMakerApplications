                &lt;/div&gt;
                &lt;div class="flex items-center space-x-2 text-gray-600 dark:text-gray-400 text-sm"&gt;
                    &lt;span&gt;2024년 11월 4일 5:42 오전&lt;/span&gt;
                &lt;/div&gt;
            &lt;/div&gt;
            
            &lt;!-- 태그들 --&gt;
            &lt;div class="flex flex-wrap gap-2 my-4"&gt;
                
                    &lt;span class="px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 text-sm font-medium rounded-full"&gt;
