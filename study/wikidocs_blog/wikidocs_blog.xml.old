                &lt;!-- 제목 --&gt;
                &lt;h1 class="text-3xl font-bold text-gray-800 dark:text-gray-200 flex-1 mb-2 sm:mb-0"&gt;테이블의 구성: 필드와 레코드&lt;/h1&gt;
                &lt;!-- Edit 버튼 --&gt;
                
            &lt;/div&gt;
            &lt;!-- 글쓴이 및 발행일자 --&gt;
