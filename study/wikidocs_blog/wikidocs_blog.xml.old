        &lt;a href="#" class="view text-sm flex items-center space-x-2"&gt;
            &lt;div class="bg-green-100 dark:bg-green-900 rounded-lg p-2 flex items-center justify-center space-x-2"&gt;
                &lt;i class="far fa-eye text-green-500 dark:text-green-300 text-lg"&gt;&lt;/i&gt;
