                            &lt;div class="w-32 h-32 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 dark:text-gray-300"&gt;
                                &lt;i class="fas fa-user text-3xl"&gt;&lt;/i&gt;
                            &lt;/div&gt;
                        
                    &lt;/a&gt;
                    &lt;div&gt;
                        &lt;h1 class="text-2xl font-bold text-gray-700 dark:text-gray-200 mb-2"&gt;
                            &lt;a href="/blog/@wishlee24/"&gt;@wishlee24&lt;/a&gt;
                        &lt;/h1&gt;
                        
                            &lt;p class="text-gray-400 dark:text-gray-500"&gt;상태 메시지가 없습니다.&lt;/p&gt;
                        
                        &lt;div class="flex items-center space-x-2"&gt;
                            &lt;!-- 구독 아이콘 --&gt;
                            &lt;span hx-post="/blog/subscribe/33/"
